#!/usr/bin/env bash
#MISE description="Install the user launchd service for mlx-video-server"
#MISE alias="install"
# Usage: mise run service:install [PORT]
#   PORT  Port number to listen on (default: 8800)
#         Can also be set via MLX_VIDEO_PORT env var.
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
LABEL="${MLX_VIDEO_SERVICE_LABEL:-io.github.kiarina.mlx-video-server}"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
PYTHON="$PROJECT_DIR/.venv/bin/python"
PORT="${1:-${MLX_VIDEO_PORT:-8800}}"

if [[ ! -x "$PYTHON" ]]; then
  echo "Missing virtualenv Python: $PYTHON" >&2
  echo "Run: uv sync" >&2
  exit 1
fi

# launchd starts with a minimal PATH that omits Homebrew, so mlx-video cannot
# find ffmpeg (used to mux audio into the mp4). Build a PATH that includes the
# directory of the ffmpeg we can see now, falling back to common locations.
FFMPEG_BIN="$(command -v ffmpeg || true)"
if [[ -z "$FFMPEG_BIN" ]]; then
  echo "Warning: ffmpeg not found on PATH; audio muxing will be disabled" >&2
fi
SERVICE_PATH="${FFMPEG_BIN:+$(dirname "$FFMPEG_BIN"):}/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

mkdir -p "$HOME/Library/LaunchAgents"

cat > "$PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>${LABEL}</string>

    <key>ProgramArguments</key>
    <array>
      <string>${PYTHON}</string>
      <string>-m</string>
      <string>uvicorn</string>
      <string>mlx_video_server.main:app</string>
      <string>--host</string>
      <string>0.0.0.0</string>
      <string>--port</string>
      <string>${PORT}</string>
    </array>

    <key>WorkingDirectory</key>
    <string>${PROJECT_DIR}</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>PATH</key>
      <string>${SERVICE_PATH}</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/mlx-video-server.out.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/mlx-video-server.err.log</string>
  </dict>
</plist>
PLIST

plutil -lint "$PLIST"
echo "Installed $PLIST"
