#!/usr/bin/env bash
#MISE description="Stop and remove the user launchd service plist"
set -euo pipefail

LABEL="${MLX_VIDEO_SERVICE_LABEL:-io.github.kiarina.mlx-video-server}"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
DOMAIN="gui/$(id -u)"

if launchctl print "${DOMAIN}/${LABEL}" >/dev/null 2>&1; then
  launchctl bootout "${DOMAIN}/${LABEL}"
fi

if [[ -f "$PLIST" ]]; then
  rm "$PLIST"
  echo "Removed $PLIST"
else
  echo "$PLIST does not exist"
fi
